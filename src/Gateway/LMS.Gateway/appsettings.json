{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "LMS.Auth.API",
    "Audience": "LMS.Client"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "courses-read-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "courses-write-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "enrollments-route": {
        "ClusterId": "enrollment-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/enrollments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://lms-auth-service:8080"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "course-destination": {
            "Address": "http://lms-course-service:8080"
          }
        }
      },
      "enrollment-cluster": {
        "Destinations": {
          "enrollment-destination": {
            "Address": "http://lms-enrollment-service:8080"
          }
        }
      }
    }
  }
}